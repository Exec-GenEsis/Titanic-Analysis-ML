# Create test-train split of dataset
X_train_base, X_test_base, y_train_base, y_test_base = tts(X_base, y)

# Initialize the pipeline described above
lr_base = Pipeline(
    steps = [
        ('scaler', StandardScaler()),
        ('logreg', LogisticRegression(max_iter = 1000, random_state = 42))
    ]
)

# Train the model on the training data
lr_base.fit(X_train_base, y_train_base)

# Predict outcomes
y_pred_train_base = lr_base.predict(X_train_base)
y_pred_test_base = lr_base.predict(X_test_base)

# Calculate Probabilities
y_proba_train_base = lr_base.predict_proba(X_train_base)[:, 1]
y_proba_test_base = lr_base.predict_proba(X_test_base)[:, 1]

# Generate and Save Report
lr_base_report = report_titanic(features_baseline,
               "Logistic Regression, Baseline Features", 
               y_train_base, 
               y_pred_train_base, 
               y_proba_train_base,
               y_test_base, 
               y_pred_test_base,
