# Define helper function for confusion matrix
def plot_cm_ax(ax, y_true, y_pred, title):
    cm = confusion_matrix(y_true, y_pred)

    sns.heatmap(
        cm,
        annot=True,
        fmt="d",
        cmap="Blues",
        xticklabels=["Did Not Survive", "Survived"],
        yticklabels=["Did Not Survive", "Survived"],
        ax=ax
    )

    ax.set_xlabel("Predicted")
    ax.set_ylabel("Actual")
    ax.set_title(title)

# Create subplot figure
fig, axes = plt.subplots(2, 2, figsize=(12, 10))
axes = axes.flatten()

# Plot test confusion matrices
for ax, (model_name, y_pred_test) in zip(axes, models_dict.items()):
    plot_cm_ax(
        ax,
        y_test_base,
        y_pred_test,
        f"{model_name}\nTest Confusion Matrix"
    )

# Display figure
plt.tight_layout()
plt.show()


